    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.25",
    "@types/ffmpeg-static": "^3.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.8.10",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.9",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
