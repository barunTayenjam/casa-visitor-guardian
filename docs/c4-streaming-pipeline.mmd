    Boundary(backend, "Express Backend  :9753  (Node.js / TypeScript)", "Container") {

        Boundary(stream_core, "Streaming Core", "Sub-system") {
            Component(stream_mgr, "StreamManager", "TypeScript вЂ” rtspManager.ts\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Socket.io frame relay via PythonWsClient\nвЂў Stores lastFrame per camera\nвЂў Adaptive FPS throttling by viewer count\nвЂў Viewer tracking (socket ID sets)\nвЂў 5-min inactivity timeout")
            Component(py_ws, "PythonWsClient", "TypeScript вЂ” pythonWsClient.ts\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў WebSocket client в†’ ws://localhost:9090\nвЂў Subscribe / unsubscribe per camera\nвЂў Receives binary JPEG + JSON events\nвЂў Re-emits as Node EventEmitter\nвЂў Auto-reconnect 1s в†’ 30s exp. backoff")
            Component(sio, "Socket.io Server", "TypeScript вЂ” index.ts\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Handlers: requestStream, stopStream, disconnect\nвЂў Bridges trackingEvent в†’ Socket.io rooms\nвЂў Emits: detection, motionDetected\n         personDetected, faceDetected")
        }

        Boundary(rest_layer, "REST API", "Interface") {
            Component(stream_ctrl, "StreamController", "TypeScript вЂ” StreamController.ts\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў GET  /api/streams/:id/live   (MJPEG)\nвЂў GET  /api/streams/:id/frame  (JPEG)\nвЂў GET  /api/streams/:id/status\nвЂў GET  /api/streaming/metrics")
        }

        Component(health_mon, "StreamHealthMonitor", "TypeScript вЂ” streamHealthMonitor.ts\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў 30-second health check cycle\nвЂў Stale detection (no frames 5 min)\nвЂў Auto-restart (max 3/hr/camera)\nвЂў Severity: info в†’ warning в†’ critical")
    }

    Boundary(python_svc, "Python OpenCV Service  :8084 / :9090  (Flask)", "Container") {

        Boundary(rtsp_pkg, "rtsp_ingestion/ Package", "Python Package") {
            Component(config_py, "config.py", "Module-level constants\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Resolution: 640Г—360, FPS: 5\nвЂў JPEG quality: 60\nвЂў MOG2 history: 200, var_thresh: 16\nвЂў Motion pixel threshold: 500\nвЂў Queue sizes: live=2, event=100")
            Component(rtsp_svc, "RTSPService", "__init__.py вЂ” Orchestrator\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Loads cameras.json\nвЂў Creates per-camera FramePipeline\nвЂў Manages lifecycle (start / stop)\nвЂў Embeds in Flask (non-blocking)")

            Boundary(ingest, "Per-Camera Pipeline (Threaded)", "Frame Processing Chain") {
                Component(ffmpeg_rdr, "FFmpegReader", "ffmpeg_reader.py вЂ” Thread\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў FFmpeg subprocess: RTSP в†’ raw BGR24\nвЂў 640Г—360 @ 5 FPS\nвЂў Reads _frame_size bytes from stdout\nвЂў Reshapes to numpy array\nвЂў Reconnect 1s в†’ 30s exp. backoff")
                Component(motion_gate, "MotionGate", "frame_pipeline.py вЂ” Stage 1\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў MOG2 background subtraction\nвЂў Warmup: 10 frames\nвЂў Threshold: 500 changed pixels\nвЂў Morphological open + close\nвЂў Filters static frames в†’ skip YOLO")
                Component(yolo, "InProcessYOLO", "frame_pipeline.py вЂ” Stage 2\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў YOLOv8n.onnx в†’ YOLOv5n в†’ yolov4-tiny\nвЂў OpenCV DNN backend (CPU)\nвЂў 640Г—640 blob input\nвЂў Class-specific confidence thresholds\nвЂў NMS 0.30, min box area 1600 pxВІ")
                Component(tracker, "ByteTracker", "byte_tracker.py вЂ” Stage 3\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Kalman filter per track (8-dim state)\nвЂў Two-round matching: high/low conf\nвЂў Track lifecycle: new в†’ tracked в†’ lost в†’ removed\nвЂў Events: track_started, track_updated, track_ended")
                Component(identity, "IdentityCache + Face Recog", "frame_pipeline.py вЂ” Stage 4\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Face recognition on new tracks only\nвЂў TTL cache: 30 s per track\nвЂў Enriches events with identity label")
                Component(live_q, "live_queue", "DropOldestQueue\nmaxsize=2\nAlways receives JPEG frame")
                Component(event_q, "event_queue", "DropOldestQueue\nmaxsize=100\nJSON metadata + optional snapshot")
            }

            Component(ws_pub, "WebSocketPublisher", "websocket_publisher.py вЂ” asyncio\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў asyncio WebSocket server on :9090\nвЂў Subscribe / unsubscribe per camera\nвЂў Two-part message: JSON metadata в†’ Binary JPEG\nвЂў Multi-client fan-out\nвЂў Dead client cleanup")
        }
    }

    %% в”Ђв”Ђ External wiring в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    Rel(ip_cam, ffmpeg_cli, "RTSP / H.264 stream", "TCP :554")
    Rel(browser, sio, "requestStream / stopStream\nReceives: frame, detection, motionDetected", "Socket.io (WebSocket)")
