{
  "name": "sentryvision-server",
  "version": "1.0.0",
  "description": "Backend server for streaming RTSP camera feeds",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:old": "nodemon --exec node --experimental-specifier-resolution=node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "init-batch-db": "tsx scripts/init-batch-db.js",
    "batch-process": "tsx scripts/runBatchProcessing.ts",
    "add-test-detections": "tsx scripts/addTestDetectionData.ts",
    "detect-from-files": "tsx scripts/detectFromFiles.ts",
    "docker:dev": "docker-compose -f ../docker-compose.dev.yml up backend --build",
    "docker:dev:logs": "docker-compose -f ../docker-compose.dev.yml logs -f backend"
  },
  "dependencies": {
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.15.6",
    "@types/redis": "^4.0.10",
    "@types/sqlite3": "^3.1.11",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "ffmpeg-static": "^5.3.0",
    "glob": "^13.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.16.3",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.25",
    "@types/ffmpeg-static": "^3.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.9",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.8",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}
