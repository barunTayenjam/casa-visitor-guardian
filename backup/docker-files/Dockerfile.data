# Data container for SentryVision media files
FROM busybox:latest

# Create directories for runtime data
RUN mkdir -p /app/public/events /app/public/snapshots /app/data

# Set permissions
RUN chmod 755 /app/public/events /app/public/snapshots /app/data

# Volume definitions
VOLUME ["/app/public/events", "/app/public/snapshots", "/app/data"]

# Default command
CMD ["true"]