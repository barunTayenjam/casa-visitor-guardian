# Test Environment Configuration for Docker Deployment
NODE_ENV=production
PORT=9753

# Frontend Configuration
FRONTEND_PORT=3020
NGINX_PORT=3020

# Backend Configuration  
BACKEND_PORT=9753

# Database Configuration (for production setup)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sentryvision_test
DB_USER=sentryvision
DB_PASSWORD=test-database-password-123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=test-redis-password-123

# JWT Configuration (test secrets)
JWT_ACCESS_SECRET=test-jwt-access-secret-256-bit
JWT_REFRESH_SECRET=test-jwt-refresh-secret-256-bit
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration (test secrets)
TOTP_SECRET=test-totp-secret-256-bit
BACKUP_CODE_ENCRYPTION_KEY=test-backup-code-encryption-key
AUDIT_INTEGRITY_SECRET=test-audit-integrity-secret

# CORS Configuration
CORS_ORIGIN=http://localhost:3020

# Storage Configuration
STORAGE_PATH=/app/data
MAX_FILE_SIZE=100MB

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Docker Configuration
COMPOSE_PROJECT_NAME=sentryvision-test