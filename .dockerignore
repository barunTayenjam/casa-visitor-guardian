# Git
.git
.gitignore
.github

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# package-lock.json - needed for npm ci

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage
.nyc_output

# Build outputs (will be created in container)
dist
build

# Logs
logs
*.log

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker files (not needed in build context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Development and testing
tmp
temp
test_output.*
**/test_output.*

# Media files (large files that shouldn't be in build context)
*.mjpeg
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.jpg
*.jpeg
*.png
*.gif

# Server-specific excludes
server/

# Public assets that will be created at runtime
public/snapshots/
public/events/

# Documentation
README.md
*.md
docs/

# Configuration files not needed in production
.eslintrc*
.prettierrc*
jest.config.*
cypress.json