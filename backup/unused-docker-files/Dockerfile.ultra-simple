FROM node:20-alpine

WORKDIR /app

# Copy only the simple API file
COPY server/simple-api.js .

# Create startup script
RUN echo '#!/bin/sh' > /start.sh && \
    echo 'echo "🚀 Starting SentryVision Ultra-Simple API..."' >> /start.sh && \
    echo 'node simple-api.js' >> /start.sh && \
    chmod +x /start.sh

# Expose port
EXPOSE 9753

# Start the application
CMD ["/start.sh"]