    "bcrypt": "^5.1.1",
    "canvas": "^3.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "ffmpeg-static": "^5.2.0",
    "glob": "^10.4.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.3",
    "pg": "^8.16.3",
    "redis": "^5.8.3",
    "sharp": "^0.34.4",
    "socket.io": "^4.7.2",
