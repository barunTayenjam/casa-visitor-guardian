# Production Environment Configuration
# Copy this file to .env.production and configure for your deployment

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=production
PORT=3000

# Domain Configuration
DOMAIN=your-domain.com
CORS_ORIGIN=https://your-domain.com,http://localhost:3000,http://localhost:5173

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sentryvision
DB_USER=sentryvision
# Generate secure password: openssl rand -base64 32
DB_PASSWORD=your-secure-database-password-here

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
# Generate secure password: openssl rand -base64 32
REDIS_PASSWORD=your-secure-redis-password-here

# ===========================================
# JWT Configuration
# ===========================================
# Generate secure secrets: openssl rand -base64 32
JWT_ACCESS_SECRET=your-jwt-access-secret-256-bit-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-256-bit-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Security Configuration
# ===========================================
# Generate secure secrets: openssl rand -base64 32
TOTP_SECRET=your-totp-secret-256-bit-here
BACKUP_CODE_ENCRYPTION_KEY=your-backup-code-encryption-key-here
AUDIT_INTEGRITY_SECRET=your-audit-integrity-secret-here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SentryVision <noreply@your-domain.com>

# ===========================================
# File Storage Configuration
# ===========================================
STORAGE_TYPE=local
STORAGE_PATH=/app/data
MAX_FILE_SIZE=100MB

# ===========================================
# Security Settings
# ===========================================
BCRYPT_ROUNDS=14
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT=30m

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m

# ===========================================
# Monitoring Configuration
# ===========================================
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
PROMETHEUS_ENABLED=true

# ===========================================
# SSL/TLS Configuration
# ===========================================
SSL_EMAIL=admin@your-domain.com
SSL_COUNTRY=US
SSL_STATE=State
SSL_CITY=City
SSL_ORGANIZATION=Your Organization

# ===========================================
# Backup Configuration
# ===========================================
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=true
BACKUP_ENCRYPTION_ENABLED=true

# ===========================================
# Performance Configuration
# ===========================================
MAX_CONNECTIONS=200
WORK_MEM=4MB
SHARED_BUFFERS=256MB
EFFECTIVE_CACHE_SIZE=1GB
MAINTENANCE_WORK_MEM=64MB

# ===========================================
# Camera Configuration
# ===========================================
MAX_CAMERAS=50
MAX_CONCURRENT_STREAMS=20
STREAM_QUALITY=high
SNAPSHOT_QUALITY=85
MOTION_DETECTION_SENSITIVITY=0.5

# ===========================================
# Facial Recognition Configuration
# ===========================================
FACIAL_RECOGNITION_ENABLED=true
FACE_DETECTION_CONFIDENCE=0.7
FACE_RECOGNITION_THRESHOLD=0.6
MAX_FACES_PER_IMAGE=10

# ===========================================
# Notification Configuration
# ===========================================
NOTIFICATION_ENABLED=true
WEBHOOK_URL=
SLACK_WEBHOOK=
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# Third-party Services
# ===========================================
# Google Cloud Storage (optional)
GCS_BUCKET=
GCS_KEY_FILE=

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Cloudflare (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ===========================================
# Development/Debug Settings
# ===========================================
DEBUG_ENABLED=false
DEBUG_SQL=false
DEBUG_REDIS=false
ENABLE_CORS_IN_DEV=false

# ===========================================
# Docker Configuration
# ===========================================
COMPOSE_PROJECT_NAME=sentryvision
COMPOSE_FILE=docker-compose.prod.yml

# ===========================================
# Health Check Configuration
# ===========================================
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# ===========================================
# Network Configuration
# ===========================================
NETWORK_SUBNET=172.20.0.0/16
BACKEND_HOST=backend
FRONTEND_HOST=frontend
NGINX_HOST=nginx

# ===========================================
# Monitoring Credentials
# ===========================================
GRAFANA_PASSWORD=your-grafana-password-here
PROMETHEUS_PASSWORD=your-prometheus-password-here

# ===========================================
# API Configuration
# ===========================================
API_VERSION=v1
API_PREFIX=/api
API_RATE_LIMIT=100
API_TIMEOUT=30000

# ===========================================
# Session Configuration
# ===========================================
SESSION_SECRET=your-session-secret-256-bit-here
SESSION_MAX_AGE=30d
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ===========================================
# Webhook Configuration
# ===========================================
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# ===========================================
# AI/ML Configuration
# ===========================================
OPENCV_THREADS=4
YOLO_MODEL_PATH=/app/models/yolo.onnx
FACE_DETECTION_MODEL_PATH=/app/models/face_detection.onnx
INFERENCE_BATCH_SIZE=4
INFERENCE_INTERVAL=1000

# ===========================================
# Compression Configuration
# ===========================================
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# ===========================================
# Cache Configuration
# ===========================================
CACHE_TTL=3600
CACHE_MAX_SIZE=100mb
CACHE_STRATEGY=lru

# ===========================================
# Rate Limiting Configuration
# ===========================================
RATE_LIMIT_STRATEGY=sliding-window
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_BURST=20

# ===========================================
# Security Headers Configuration
# ===========================================
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=63072000

# ===========================================
# Database Pool Configuration
# ===========================================
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=60000
DB_POOL_EVICTION=1000

# ===========================================
# Migration Configuration
# ===========================================
MIGRATIONS_TABLE=migrations
MIGRATIONS_LOCK_TABLE=migrations_lock
MIGRATIONS_DIR=database/migrations

# ===========================================
# Seed Configuration
# ===========================================
# REQUIRED in production — server will not start without these
SEED_ADMIN_USER=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# ===========================================
# Error Handling Configuration
# ===========================================
ERROR_NOTIFICATION_ENABLED=true
ERROR_SLACK_WEBHOOK=
ERROR_EMAIL_RECIPIENTS=

# ===========================================
# Feature Flags
# ===========================================
FEATURE_MFA_ENABLED=true
FEATURE_FACIAL_RECOGNITION=true
FEATURE_PERSON_DETECTION=true
FEATURE_VEHICLE_DETECTION=false
FEATURE_LICENSE_PLATE_RECOGNITION=false
FEATURE_BEHAVIOR_ANALYSIS=false

# ===========================================
# Integration Configuration
# ===========================================
ZABBIX_ENABLED=false
ZABBIX_SERVER=
ZABBIX_PORT=10051

DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_SITE=

NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=

# ===========================================
# Compliance Configuration
# ===========================================
GDPR_ENABLED=true
HIPAA_ENABLED=false
SOX_ENABLED=false
AUDIT_RETENTION_YEARS=7

# ===========================================
# Testing Configuration
# ===========================================
TEST_DATABASE=sentryvision_test
TEST_REDIS_DB=1
TEST_JWT_SECRET=test-jwt-secret

# ===========================================
# OpenCV Service Configuration
# ===========================================
OPENCV_SERVICE_URL=http://localhost:8084

# ===========================================
# Detection Pipeline Configuration
# ===========================================
PIPELINE_MODE=python-only
PYTHON_WS_URL=ws://localhost:9090

# ===========================================
# Detection Storage Configuration
# ===========================================
DETECTIONS_DIR=./data/detections
DETECTIONS_RETENTION_DAYS=30

# ===========================================
# Streaming Configuration
# ===========================================
FRAME_INTERVAL=40
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5000

# ===========================================
# Credential Encryption
# ===========================================
# AES-256-GCM key for encrypting stored RTSP credentials
CREDENTIAL_ENCRYPTION_KEY=

# ===========================================
# NVIDIA AI Vision Analysis Configuration
# ===========================================
# NVIDIA Build API key for AI vision analysis
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# ===========================================
# Web Push VAPID Keys
# ===========================================
# Web Push VAPID keys for browser notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ===========================================
# Custom Configuration
# ===========================================
# Add any custom environment variables here
CUSTOM_VAR_1=
CUSTOM_VAR_2=