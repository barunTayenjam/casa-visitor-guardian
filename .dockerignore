.env.test.local
.env.production.local
.envrc

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.vimrc

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker files (not needed in build context)
Dockerfile*
docker-compose*.yml
.dockerignore
docker-compose.override.yml

# Development and testing
tmp
temp
test_output.*
**/test_output.*
test-results
jest
.cypress

# Media files (large files that shouldn't be in build context)
*.mjpeg
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.tif
*.webp

