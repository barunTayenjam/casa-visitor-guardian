# Production Environment Configuration for Deployment
NODE_ENV=production
PORT=3000

# Domain Configuration - UPDATE THESE FOR YOUR DEPLOYMENT
DOMAIN=localhost
CORS_ORIGIN=http://localhost

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sentryvision
DB_USER=sentryvision
DB_PASSWORD=your-secure-database-password-here-change-this

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password-here-change-this

# JWT Configuration - GENERATE NEW SECRETS FOR PRODUCTION
JWT_ACCESS_SECRET=your-jwt-access-secret-256-bit-change-this
JWT_REFRESH_SECRET=your-jwt-refresh-secret-256-bit-change-this

# Security Configuration - GENERATE NEW SECRETS FOR PRODUCTION
TOTP_SECRET=your-totp-secret-256-bit-change-this
BACKUP_CODE_ENCRYPTION_KEY=your-backup-code-encryption-key-change-this
AUDIT_INTEGRITY_SECRET=your-audit-integrity-secret-change-this

# Docker Configuration
COMPOSE_PROJECT_NAME=sentryvision-prod
FRONTEND_PORT=3000
BACKEND_PORT=9753

# Data Paths - Using local directories for persistence
POSTGRES_DATA_PATH=./data/postgres
REDIS_DATA_PATH=./data/redis
SNAPSHOTS_PATH=./data/snapshots
EVENTS_PATH=./data/events
LOGS_PATH=./logs/backend
UPLOADS_PATH=./data/uploads

# Logging Configuration
LOG_LEVEL=info

# File Storage Configuration
MAX_FILE_SIZE=100MB