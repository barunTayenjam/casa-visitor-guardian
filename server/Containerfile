# Backend Podmanfile - Simplified Sharp-only build
FROM node:18-alpine

# Runtime dependencies only (no build tools!)
RUN apk add --no-cache \
    curl \
    ffmpeg \
    python3 \
    py3-pip \
    py3-setuptools \
    py3-distutils-extra \
    && rm -rf /var/cache/apk/*

# Install setuptools as fallback for distutils
RUN pip3 install setuptools --break-system-packages

# Prevent sharp from trying to use global libvips (even if present)
ENV SHARP_IGNORE_GLOBAL_LIBVIPS=1

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S sentryvision -u 1001

WORKDIR /app

# Copy package files
COPY package*.json ./

# Set Python path for node-gyp
ENV PYTHON=/usr/bin/python3

# Install dependencies — explicitly request musl binary (npm >=10)
# This ensures sharp uses prebuilt linuxmusl-x64 binary, avoiding source build
RUN npm ci --cpu=x64 --os=linux --libc=musl && npm cache clean --force

# Copy Simple JavaScript file (CommonJS) - copy before other files
COPY --chown=sentryvision:nodejs server-simple.cjs ./server.cjs

# Copy source code
COPY --chown=sentryvision:nodejs src/ ./src/
COPY --chown=sentryvision:nodejs tsconfig.json ./
COPY --chown=sentryvision:nodejs .env.example ./
COPY --chown=sentryvision:nodejs jest.config.js ./

# Create runtime directories
RUN mkdir -p /app/logs /app/uploads /app/snapshots /app/events && \
    chown -R sentryvision:nodejs /app

# Switch to non-root user
USER sentryvision

# Environment
ENV NODE_ENV=production
ENV PORT=8082
ENV TZ=UTC

EXPOSE 8082

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8082/api/health || exit 1

# Start app
CMD ["node", "server.cjs"]