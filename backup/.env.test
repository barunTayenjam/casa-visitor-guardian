# Test Environment Configuration for Docker Testing
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sentryvision_test
DB_USER=sentryvision
DB_PASSWORD=test-database-password-123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=test-redis-password-123

# JWT Configuration
JWT_ACCESS_SECRET=test-jwt-access-secret-256-bit
JWT_REFRESH_SECRET=test-jwt-refresh-secret-256-bit

# Security Configuration
TOTP_SECRET=test-totp-secret-256-bit
BACKUP_CODE_ENCRYPTION_KEY=test-backup-code-encryption-key
AUDIT_INTEGRITY_SECRET=test-audit-integrity-secret

# CORS Configuration
CORS_ORIGIN=http://localhost

# File Storage Configuration
MAX_FILE_SIZE=100MB

# Logging Configuration
LOG_LEVEL=info

# Docker Configuration
COMPOSE_PROJECT_NAME=sentryvision-test
FRONTEND_PORT=3000
BACKEND_PORT=9753

# Data Paths
POSTGRES_DATA_PATH=./test-data/postgres
REDIS_DATA_PATH=./test-data/redis
SNAPSHOTS_PATH=./test-data/snapshots
EVENTS_PATH=./test-data/events
LOGS_PATH=./test-logs/backend
UPLOADS_PATH=./test-data/uploads