server/
server-src
server/**/src/
server/**/*.test.*
server/**/*.spec.*

# Public assets that will be created at runtime
public/snapshots/
public/events/
public/uploads/

# Documentation
README.md
*.md
docs/
*.pdf
*.txt

# Configuration files not needed in production
.eslintrc*
.prettierrc*
